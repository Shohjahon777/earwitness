# Pull the real values with: vercel env pull .env.local
# (or copy this to .env and fill in)

# Marketplace Postgres (Neon) — provisioned via Vercel Marketplace
DATABASE_URL="postgresql://user:password@host/db?sslmode=require"

# Vercel Blob — clip storage
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxx"

# Vercel AI Gateway — used by the offline pipeline's LLM adapter
AI_GATEWAY_API_KEY="vck_xxx"

# Offline pipeline provider keys (only the stacks you wire for real need these)
ELEVENLABS_API_KEY=""

# Protects the ranking cron route
CRON_SECRET=""
