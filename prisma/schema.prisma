// Earwitness data model.
// Mirrors the UI contracts in lib/types.ts. The web app only does cheap CRUD +
// ranking; all audio is rendered offline by the Python pipeline and cached in Vercel Blob.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// A deployable voice-agent stack (STT + LLM + TTS + turn handling). The thing we rank.
// The "human agent" is modeled as a stack with isHuman = true (golden-ears only).
model Stack {
  id        String   @id
  name      String
  stt       String
  llm       String
  tts       String
  turns     String
  isHuman   Boolean  @default(false)

  clips     Clip[]
  ratings   StackRating[]
  createdAt DateTime @default(now())
}

// A scripted conversation situation. `type` decides which leaderboard dimension a vote feeds.
model Scenario {
  id      String       @id
  label   String // neutral, shown pre-vote (no spoilers)
  insight String // one-line "why this matters", shown at reveal
  type    ScenarioType

  clips   Clip[]
  rounds  Round[]
}

enum ScenarioType {
  interrupt
  pause
  accent
  clean
}

enum Mode {
  arena
  golden_ears
}

// One rendered clip = one (scenario x stack) recording, cached in Blob. The pairing mode
// (arena vs golden-ears) is decided when two clips are matched into a Round, not here.
model Clip {
  id          String   @id @default(cuid())
  scenarioId  String
  stackId     String
  blobUrl     String
  durationSec Float
  transcript  Json // timeline + who-said-what for the post-vote reveal

  scenario    Scenario @relation(fields: [scenarioId], references: [id])
  stack       Stack    @relation(fields: [stackId], references: [id])

  roundsAsA   Round[]  @relation("ClipA")
  roundsAsB   Round[]  @relation("ClipB")

  createdAt   DateTime @default(now())

  @@unique([scenarioId, stackId])
}

// Anonymous cookie session. Aggregates are cached so getMe / listeners reads stay O(1).
model Session {
  id            String   @id // cookie value
  handle        String   @unique // "Listener-7F2"
  votes         Int      @default(0)
  geVotes       Int      @default(0) // golden-ears votes
  geCorrect     Int      @default(0) // golden-ears correct guesses
  streak        Int      @default(0) // current golden-ears (answer) streak
  longestStreak Int      @default(0)

  // --- gamification economy (level/rank are computed from xp, never stored) ---
  coins         Int      @default(0) // spendable "credits"
  xp            Int      @default(0) // lifetime "signal" → drives Ear Rank

  // --- daily-login streak (distinct from the answer streak above) ---
  lastLoginDate      String? // YYYY-MM-DD (UTC) of last login-bonus claim
  loginStreak        Int     @default(0)
  longestLoginStreak Int     @default(0)

  // --- consumables + cosmetics ---
  freezesOwned  Int      @default(0) // streak-freeze items
  hintsOwned    Int      @default(0) // golden-ears hint credits
  theme         String   @default("booth") // selected cosmetic theme
  ownedThemes   String[] @default(["booth"])

  // --- Ear Engine: Glicko-2 rating of the user's "ear" (golden-ears skill) ---
  earRating     Float    @default(1500) // μ on the rating scale
  earRd         Float    @default(350)  // rating deviation (uncertainty)
  earVol        Float    @default(0.06) // volatility σ

  // --- pity timer: votes since the last 2× "signal bonus" ---
  bonusDry      Int      @default(0)

  votesCast     Vote[]
  dailyResults  DailyResult[]
  achievements  Achievement[]
  quests        QuestProgress[]
  coinLedger    CoinLedger[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// Per-AI-stack "deception" rating (Glicko-2): how convincingly it imitates a human in
// golden-ears. The opponent the user's ear plays against each golden-ears round.
model StackDeception {
  stackId   String   @id
  rating    Float    @default(1500)
  rd        Float    @default(350)
  vol       Float    @default(0.06)
  games     Int      @default(0)
  updatedAt DateTime @updatedAt
}

// Tagged coin faucet/sink events — powers the live economy panel on /system.
// Positive delta = faucet (earned), negative = sink (spent).
model CoinLedger {
  id        String   @id @default(cuid())
  sessionId String
  delta     Int
  source    String // vote | bonus | jackpot | quest | achievement | login | daily | purchase
  createdAt DateTime @default(now())

  session   Session  @relation(fields: [sessionId], references: [id])

  @@index([source])
  @@index([createdAt])
}

// One row per unlocked badge. Definitions live in code (lib/server/gamification.ts).
model Achievement {
  id            String   @id @default(cuid())
  sessionId     String
  achievementId String // matches a definition id in code
  unlockedAt    DateTime @default(now())

  session       Session  @relation(fields: [sessionId], references: [id])

  @@unique([sessionId, achievementId])
}

// Per-day progress toward a quest. Quest defs are deterministic-by-date and live in code.
model QuestProgress {
  id        String  @id @default(cuid())
  sessionId String
  date      String // YYYY-MM-DD (UTC)
  questId   String
  progress  Int     @default(0)
  target    Int
  claimed   Boolean @default(false)

  session   Session @relation(fields: [sessionId], references: [id])

  @@unique([sessionId, date, questId])
  @@index([sessionId, date])
}

// Persisted when a round is served, so submitVote can validate the pick and reveal authoritatively.
model Round {
  id           String   @id @default(cuid())
  mode         Mode
  scenarioId   String
  clipAId      String
  clipBId      String
  humanChannel Channel? // golden-ears: which side is the human

  scenario     Scenario @relation(fields: [scenarioId], references: [id])
  clipA        Clip     @relation("ClipA", fields: [clipAId], references: [id])
  clipB        Clip     @relation("ClipB", fields: [clipBId], references: [id])

  votes        Vote[]
  createdAt    DateTime @default(now())
}

enum Channel {
  A
  B
}

// Source of truth for ranking. One vote per (round, session).
model Vote {
  id           String       @id @default(cuid())
  roundId      String
  sessionId    String
  pick         String // "A" | "B" | "tie"
  correct      Boolean? // golden-ears only
  scenarioType ScenarioType
  mode         Mode

  round        Round        @relation(fields: [roundId], references: [id])
  session      Session      @relation(fields: [sessionId], references: [id])
  createdAt    DateTime     @default(now())

  @@unique([roundId, sessionId])
  @@index([mode, scenarioType])
}

enum Dimension {
  overall
  naturalness
  interaction
}

// Live Elo writes here per vote; the Bradley-Terry cron overwrites rating/CI/trend.
model StackRating {
  stackId   String
  dimension Dimension
  rating    Float     @default(1200)
  ratingCI  Float     @default(0)
  votes     Int       @default(0)
  trend     Json      @default("[]") // recent rating sparkline

  stack     Stack     @relation(fields: [stackId], references: [id])
  updatedAt DateTime  @updatedAt

  @@id([stackId, dimension])
}

// One row per (session, date). Enforces "already done today".
model DailyResult {
  id         String   @id @default(cuid())
  sessionId  String
  date       String // YYYY-MM-DD (UTC)
  score      Int
  percentile Int
  answers    Json
  shareId    String   @unique

  session    Session  @relation(fields: [sessionId], references: [id])
  createdAt  DateTime @default(now())

  @@unique([sessionId, date])
  @@index([date])
}

// Tiny key/value for server bookkeeping (e.g. last Bradley–Terry recompute timestamp).
// Lets the leaderboard self-heal without a cron — see lib/server/ranking.ts.
model Meta {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

// Snapshot written by submitVote/submitDaily; read by getShareCard + the OG image route.
model ShareCard {
  id         String   @id // shareId
  handle     String
  mode       String // "daily" | "golden-ears" | "matchup"
  accuracy   Int
  score      Int?
  percentile Int?
  streak     Int
  tagline    String
  createdAt  DateTime @default(now())
}
